# .env.local — copy to .env.local and fill in your values
# Never commit this file to git

# ── Required: The Odds API ────────────────────────────────────
# Free tier: 500 requests/month
# Sign up: https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# ── Required: Vercel KV (shared portfolio storage) ────────────
# Created automatically when you add KV to your Vercel project
# Dashboard: https://vercel.com/dashboard → Storage → Create KV
KV_URL=your_kv_url_here
KV_REST_API_URL=your_kv_rest_url_here
KV_REST_API_TOKEN=your_kv_token_here
KV_REST_API_READ_ONLY_TOKEN=your_kv_read_only_token_here

# ── Required: Cron security ───────────────────────────────────
# Any random string — prevents unauthorized cron triggers
# Generate: openssl rand -hex 32
CRON_SECRET=your_random_secret_here

# ── Optional: TheRundown (player props) ──────────────────────
# Free: 20k datapoints/day — https://therundown.io/api
RUNDOWN_API_KEY=

# ── Optional: Anthropic (AI news agent) ──────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=
